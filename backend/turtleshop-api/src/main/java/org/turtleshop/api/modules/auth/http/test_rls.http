// == Register a new customer ==
POST http://localhost:8080/api/auth/register
Content-Type: application/json

{
  "email": "test1@turtleshop.org",
  "firstName": "Test",
  "lastName": "User1",
  "password": "password123",
  "role": "CUSTOMER"
}

// == Login with the new customer ==
POST http://localhost:8080/api/auth/login
Content-Type: application/json

{
  "email": "test1@turtleshop.org",
  "password": "password123"
}

// == Get current user info (should work) ==
GET http://localhost:8080/api/auth/me
Authorization: Bearer {{response.body.token}}

// == Get all customers (should fail or show only admin before RLS) ==
GET http://localhost:8080/api/customer
Authorization: Bearer {{response.body.token}}

// == Get customer by ID (the new one we just registered) ==
// Note: We need to know the customer_id from the registration response.
// For now, let's assume we got it or we can hardcode a test ID.
// In a real scenario, you would extract the customer_id from the registration response.
GET http://localhost:8080/api/customer/123e4567-e89b-12d3-a456-426614174000
Authorization: Bearer {{response.body.token}}

// == Get customer "me" (should work) ==
GET http://localhost:8080/api/auth/me
Authorization: Bearer {{response.body.token}}

// == Test with a wrong customer ID (should fail with RLS) ==
GET http://localhost:8080/api/customer/123e4567-e89b-12d3-a456-426614174001
Authorization: Bearer {{response.body.token}}

// == Logout (optional) ==
POST http://localhost:8080/api/auth/logout
Authorization: Bearer {{response.body.token}}

// == Register another customer for comparison ==
POST http://localhost:8080/api/auth/register
Content-Type: application/json

{
  "email": "test2@turtleshop.org",
  "firstName": "Test",
  "lastName": "User2",
  "password": "password456",
  "role": "CUSTOMER"
}

// == Login with the second customer ==
POST http://localhost:8080/api/auth/login
Content-Type: application/json

{
  "email": "test2@turtleshop.org",
  "password": "password456"
}

// == Get current user info (should work) ==
GET http://localhost:8080/api/auth/me
Authorization: Bearer {{response.body.token}}

// == Get all customers (should still fail or show only admin) ==
GET http://localhost:8080/api/customer
Authorization: Bearer {{response.body.token}}

// == Get customer by ID (the second new one) ==
// Again, you need to know the customer_id from the registration response.
GET http://localhost:8080/api/customer/45678901-2345-6789-abcd-123456789abc
Authorization: Bearer {{response.body.token}}

// == Get customer "me" (should work) ==
GET http://localhost:8080/api/auth/me
Authorization: Bearer {{response.body.token}}

// == Logout ==
POST http://localhost:8080/api/auth/logout
Authorization: Bearer {{response.body.token}}